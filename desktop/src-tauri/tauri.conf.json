{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Key Finder",
  "version": "1.0.0",
  "identifier": "com.freakngenius.keyfinder",
  "build": {
    "beforeDevCommand": "node scripts/build-dist.mjs",
    "beforeBuildCommand": "node scripts/build-dist.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Key Finder",
        "width": 1240,
        "height": 840,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    }
  }
}
